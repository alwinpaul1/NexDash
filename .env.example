# Copy to .env and fill in a key. The dispatcher agent picks its provider by
# whichever key is set (MiniMax preferred). Everything except the agent/CLI
# works fully offline, so a key is only needed for live chat.

# MiniMax (default) — OpenAI-compatible; model MiniMax-M2.7.
MINIMAX_API_KEY=
# Optional: override the model id.
# NEXDASH_LLM_MODEL=MiniMax-M2.7

# Fallback provider — Anthropic Claude (claude-opus-4-8), used if no MiniMax key.
# ANTHROPIC_API_KEY=
